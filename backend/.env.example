# AI Chatbot Backend - Environment Variables
# Copy this file to .env and fill in the values

# Project Configuration
ENVIRONMENT=development
DEBUG=true

# Database (Supabase PostgreSQL)
# Get these from your Supabase project: Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Configuration
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_KEY=[YOUR-ANON-PUBLIC-KEY]
SUPABASE_JWT_SECRET=[YOUR-JWT-SECRET]  # Get from Settings > API > JWT Settings

# OpenAI API (for embeddings and chat)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic API (Claude models)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini API
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-pro

# Multi-model settings
DEFAULT_LLM_PROVIDER=openai  # openai, anthropic, gemini
ENABLE_PROVIDER_FALLBACK=true

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=documents

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# File Upload
MAX_UPLOAD_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,txt,docx,md